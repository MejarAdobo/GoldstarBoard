{
	"expo": {
		"name": "GoldStarboard",
		"slug": "gold-starboard",
		"version": "1.0.0",
		"orientation": "portrait",
		"icon": "./assets/images/icon.png",
		"scheme": "goldstarboard",
		"userInterfaceStyle": "automatic",
		"newArchEnabled": true,
		"ios": {
			"supportsTablet": true
		},
		"android": {
			"adaptiveIcon": {
				"backgroundColor": "#FFF9F0",
				"foregroundImage": "./assets/images/adaptive-icon.png",
				"backgroundImage": "./assets/images/adaptive-icon.png",
				"monochromeImage": "./assets/images/adaptive-icon.png"
			},
			"edgeToEdgeEnabled": true,
			"predictiveBackGestureEnabled": false,
			"package": "com.momoy.goldstarboard"
		},
		"web": {
			"output": "static",
			"favicon": "./assets/images/favicon.png",
			"bundler": "metro"
		},
		"plugins": [
			"expo-router",
			[
				"expo-splash-screen",
				{
					"image": "./assets/images/splash-icon.png",
					"imageWidth": 200,
					"resizeMode": "contain",
					"backgroundColor": "#FFF9F0",
					"dark": {
						"backgroundColor": "#FFF9F0"
					}
				}
			],
			"expo-font",
			"expo-image",
			"expo-web-browser"
		],
		"experiments": {
			"typedRoutes": false,
			"reactCompiler": true
		},
		"extra": {
			"router": {},
			"eas": {
				"projectId": "32b8d421-dff6-4596-8b01-3edcce1d5286"
			}
		},
		"owner": "momoy"
	}
}
