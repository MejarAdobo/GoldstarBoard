{
  "extends": ["astro/tsconfigs/strict", "@goldstarboard/ts-config/base.json"],
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "noEmit": true,
    "paths": {
      "@src/*": ["./src/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@components/*": ["./src/components/*"],
      "@styles/*": ["./src/styles/*"]
    }
  }
}
