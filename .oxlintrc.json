{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn",
    "style": "warn"
  },
  "options": {
    "typeAware": true,
    "typeCheck": true
  },
  "rules": {
    "sort-keys": "off",
    "no-magic-numbers": "off",
    "id-length": "off"
  },
  "env": {
    "builtin": true
  }
}
